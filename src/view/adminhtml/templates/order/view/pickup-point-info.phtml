use Innosend\PickupPoints\ViewModel\Adminhtml\Order\PickupPointInfoViewmodel;
use Magento\Backend\Block\Template;
use Magento\Framework\Escaper;

/** @var PickupPointInfoViewmodel $viewModel */
/** @var Template $block */
/** @var Escaper $escaper */

$viewModel = $block->getData('pickupPointViewModel');
if (!$viewModel || !$viewModel->hasPickupPoint()) {
    return '';
}

$name        = $viewModel->getPickupPointName();
$address     = $viewModel->getPickupPointAddress();
$carrier     = $viewModel->getPickupPointCarrier();
$carrierName = $viewModel->getFormattedCarrierName();
$imageUrl    = $block->getViewFileUrl('Innosend_PickupPoints::images/carriers/' . $carrier . '.svg');

// Format address: first comma = <br>, remove second comma
$addressParts = array_map('trim', explode(',', $address, 2)); // Split on FIRST comma only
$formattedAddress = $addressParts[0] ?? ''; // First part: "Peizerweg 89"
if (isset($addressParts[1])) {
    // Second part: remove any extra commas and add on new line
    $formattedAddress .= '<br>' . str_replace(',', '', $addressParts[1]); // "Groningen"
}
?>

<div class="fm-innosend-pickup-point">
    <div class="fm-innosend-pickup-point__header">
        <?= $block->escapeHtml(__('Pickup Point Information')) ?>
    </div>
    <div class="fm-innosend-pickup-point__content">
        <div class="fm-innosend-pickup-point__content--pp">
            <?php if ($name): ?>
                <span class="fm-innosend-pickup-point__content--name">
                    <?= $escaper->escapeHtml($name) ?>
                </span>
            <?php endif; ?>

            <?php if ($address): ?>
                <span class="fm-innosend-pickup-point__content--address">
                    <?= /* @noEscape */ $formattedAddress ?>
                </span>
            <?php endif; ?>
        </div>
        <?php if ($carrier): ?>
            <img src="<?= $escaper->escapeUrl($imageUrl) ?>"
                 alt="<?= $escaper->escapeHtml($carrierName) ?>"
                 class="fm-innosend-pickup-point__content--logo logo-<?= $carrier ?>"
            />
        <?php endif; ?>
    </div>
</div>
