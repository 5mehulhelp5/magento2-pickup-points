<!-- ko if: isModalVisible() -->
<div class="innosend-pickup-points-modal" data-bind="click: function(data, event) { if (event.target === $element) closeModal(); }">
    <div class="modal-inner">
        <div class="modal-header">
            <h2><?= $escaper->escapeHtml(__('Select Pickup Point')) ?></h2>
            <button type="button" class="close" data-bind="click: closeModal">×</button>
        </div>
        <div class="modal-content">
            <!-- ko if: isLoading() -->
            <div class="loading"><?= $escaper->escapeHtml(__('Loading pickup points...')) ?></div>
            <!-- /ko -->
            <!-- ko ifnot: isLoading() -->
            <div class="pickup-points-container">
                <!-- Left: List of Pickup Points -->
                <div class="pickup-points-list-container" data-bind="css: { 'show-maps-mobile': showMapMobile() }">
                <div class="pickup-points-list">
                    <!-- ko foreach: sortedPickupPoints() -->
                    <div class="pickup-point-item"
                         data-bind="click: $parent.selectPickupPoint.bind($parent, $data),
                                    css: { 'selected': $parent.selectedPickupPoint() && $parent.selectedPickupPoint().id === id }">
                        <!-- ko if: logo -->
                        <div class="pickup-point-logo">
                            <img data-bind="attr: { src: logo, alt: carrier }" />
                        </div>
                        <!-- /ko -->
                        <div class="pickup-point-info">
                            <div class="pickup-point-name" data-bind="text: name"></div>
                            <!-- ko if: distance -->
                            <div class="pickup-point-distance" data-bind="text: distance + ' km'"></div>
                            <!-- /ko -->
                        </div>
                        <!-- ko if: $parent.selectedPickupPoint() && $parent.selectedPickupPoint().id === id -->
                        <div class="pickup-point-selected-details">
                            <div class="pickup-point-address" data-bind="text: address"></div>
                            <!-- ko if: opening_hours && opening_hours.length -->
                            <div class="pickup-point-hours">
                                <table class="business-hours-table">
                                    <thead>
                                        <tr>
                                            <th data-bind="text: $parent.$t('Day')"></th>
                                            <th data-bind="text: $parent.$t('Business Hours')"></th>
                                        </tr>
                                    </thead>
                                    <tbody data-bind="foreach: opening_hours">
                                        <tr>
                                            <td data-bind="text: day || $data.day"></td>
                                            <td data-bind="text: hours || $data.hours || $data"></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <!-- /ko -->
                            <button type="button" class="action primary choose-pickup-point"
                                    data-bind="click: $parent.confirmPickupPoint.bind($parent, $data)">
                                <span data-bind="text: $parent.$t('Choose this Pickup Point')"></span>
                            </button>
                        </div>
                        <!-- /ko -->
                    </div>
                    <!-- /ko -->
                </div>
                </div>
                <!-- Right: Map -->
                <!-- ko if: shouldShowMap() -->
                <div class="pickup-points-map" id="innosend-pickup-points-map"></div>
