<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="sales_model_service_quote_submit_before">
        <observer name="innosend_pickup_points_transfer_to_order" instance="Innosend\PickupPoints\Observer\QuoteSubmitBefore"/>
    </event>
    <event name="sales_order_place_after">
        <observer name="innosend_pickup_points_log_order_creation" instance="Innosend\PickupPoints\Observer\SalesOrderPlaceAfter"/>
    </event>
    <event name="sales_order_save_after">
        <observer name="innosend_pickup_points_save_order_data" instance="Innosend\PickupPoints\Observer\SalesOrderPlaceAfter"/>
    </event>
    <event name="email_order_set_template_vars_before">
        <observer name="innosend_pickup_points_replace_email_shipping_address"
                  instance="Innosend\PickupPoints\Observer\EmailOrderSetTemplateVarsBefore"/>
    </event>
</config>
