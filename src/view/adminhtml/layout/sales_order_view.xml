<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="order_shipping_view">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Innosend_PickupPoints::order/view/shipping-and-handling-info.phtml</argument>
            </action>
            <container name="extra_shipping_info">
                <block class="Magento\Backend\Block\Template" name="innosend_pickup_points_info"
                       template="Innosend_PickupPoints::order/view/pickup-point-info.phtml">
                    <arguments>
                        <argument name="pickupPointViewModel" xsi:type="object">
                            Innosend\PickupPoints\ViewModel\Adminhtml\Order\PickupPointInfoViewmodel
                        </argument>
                    </arguments>
                </block>
            </container>
        </referenceBlock>
    </body>
</page>
