{
    "name": "innosend/magento2-pickup-points",
    "description": "Innosend Pickup Points Module for Magento 2 - Checkout integration",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": [
        "OSL-3.0",
        "AFL-3.0"
    ],
    "authors": [
        {
            "name": "Falcon Media",
            "email": "info@falconmedia.nl"
        }
    ],
    "require": {
        "php": "~7.3.0||~7.4.0||~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": ">=102.0.0",
        "magento/module-checkout": ">=100.0.0",
        "magento/module-quote": ">=101.0.0",
        "magento/module-sales": ">=102.0.0",
        "innosend/magento2-base": "^1.0.0"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "Innosend\\PickupPoints\\": "src/"
        }
    },
    "extra": {
        "map": [
            [
                "*",
                "Innosend/PickupPoints"
            ]
        ]
    }
}














